# scrape_bigfinance.py 무인 실행(스케줄러)용 EPIC Finance(bigfinance.co.kr) 로그인 정보.
# 비워두면 기존과 동일하게 브라우저 창에서 사람이 직접 로그인하는 방식으로 동작한다.
# 값을 채우면 로그인 페이지가 뜰 때 자동으로 입력을 시도하고, 실패하면(셀렉터가 안 맞거나
# 캡차/OTP 등 추가 인증이 뜨는 경우) 기존처럼 수동 로그인 대기로 자동 폴백한다.
EPIC_FINANCE_ID=
EPIC_FINANCE_PW=

# 사용법: 이 파일을 .env로 복사한 뒤 실제 값을 채워 넣는다.
#   cp .env.example .env
# .env는 .gitignore에 등록되어 있어 커밋되지 않는다. 절대 이 값을 채팅이나 커밋 메시지에
# 붙여넣지 않는다.
